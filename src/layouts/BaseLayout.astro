---
import "../globals.css";

export interface Props {
  title?: string;
}

const { title = "Sam Thomas" } = Astro.props;
const pageTitle = title === "Sam Thomas" ? title : `${title} - Sam Thomas`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main class="min-h-screen max-w-5xl mx-auto px-6 py-12 flex flex-col">
      <slot />
    </main>
  </body>
</html>