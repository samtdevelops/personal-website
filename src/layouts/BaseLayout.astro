---
import { site } from "../site.config";
import "../globals.css";

interface Props {
  title: string;
  description: string;
  heading: string;
  noindex?: boolean;
}

const { title, description, heading, noindex = false } = Astro.props;
const isHome = Astro.url.pathname === "/";
const pageTitle = isHome ? title : `${title} | ${site.name}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url).href;
const ogImageUrl = new URL("/og.jpeg", site.url).href;
const ogImageAlt = "Sam Thomas, a software engineer based in the UK";
const personJsonLd = isHome
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: site.name,
      url: site.url,
      email: site.email,
      jobTitle: "Software Engineer",
      sameAs: [site.github, site.linkedin],
    })
  : null;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {
      personJsonLd && (
        <script type="application/ld+json" set:html={personJsonLd} />
      )
    }
    <title>{pageTitle}</title>
  </head>

  <body>
    <main>
      <h1>{heading}</h1>
      <slot />
    </main>

    <hr />

    <footer>
      <p>
        <small>
          <a href="/">{site.name}</a> &copy; {new Date().getFullYear()}
        </small>
      </p>
    </footer>
  </body>
</html>
