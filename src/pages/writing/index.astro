---
import { getCollection } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";
import WritingFilter from "../../components/WritingFilter.astro";
import PostMeta from "../../components/PostMeta.astro";

const posts = await getCollection("writing");
posts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
---

<ContentLayout title="Writing" heading="Writing">
  <p class="subtitle mt-3">
    I write about two things from first principles. Technical concepts as a
    software engineer, and all things hypertrophy, nutrition and fitness. Read
    whichever you like.
  </p>

  <WritingFilter>
    {
      posts.map((post) => (
        <article data-category={post.data.category}>
          <h2 class="post-title">
            <a href={`/writing/${post.id}`}>{post.data.title}</a>
          </h2>

          <PostMeta
            category={post.data.category}
            publishDate={post.data.publishDate}
          />

          {post.data.excerpt && <p class="mt-3">{post.data.excerpt}</p>}
        </article>
      ))
    }
  </WritingFilter>
</ContentLayout>
