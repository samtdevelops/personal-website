---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site.config";
---

<BaseLayout
  title="Contact"
  description="Ways to get in touch with Sam Thomas."
  heading="Contact"
>
  <p>Feel free to reach out.</p>

  <ul>
    <li>
      <a href={`mailto:${site.email}`}>{site.email}</a> - email me directly
    </li>
    <li>
      <a href={site.linkedin}>LinkedIn</a> - connect with me on LinkedIn
    </li>
    <li>
      <a href={site.github}>GitHub</a> - check out my code
    </li>
  </ul>
</BaseLayout>
